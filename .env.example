# Brew & Bloom Cafe — Environment Variables
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local to version control.

# ── WhatsApp ──────────────────────────────────────────────────
# The owner's WhatsApp number that receives order and reservation messages.
# Format: country code + number with no spaces, '+', or dashes.
# Example: 911234567890  (India +91, number 1234567890)
VITE_WHATSAPP_NUMBER=

# ── Google Maps ──────────────────────────────────────────────
# The embed URL from Google Maps > Share > Embed a map.
# Example: https://www.google.com/maps/embed?pb=...
VITE_GOOGLE_MAPS_EMBED_URL=

# ── Newsletter ────────────────────────────────────────────────
# The deployed Google Apps Script web app URL that accepts POST requests
# and writes email/phone to a Google Sheet.
VITE_GOOGLE_SHEET_SCRIPT_URL=

# ── Contact ───────────────────────────────────────────────────
# Cafe phone number for the click-to-call button.
# Include country code, e.g. +91-80-12345678
VITE_CAFE_PHONE_NUMBER=

# ── QR Code Admin ────────────────────────────────────────────
# Number of tables in the cafe. Used as the default value on /admin/qr.
VITE_TABLE_COUNT=10

# ── Site Origin ──────────────────────────────────────────────
# The canonical public URL of the deployed site (no trailing slash).
# Used when constructing QR code URLs.
VITE_SITE_ORIGIN=https://brewandbloom.cafe

# ── Admin Panel ───────────────────────────────────────────────
# PIN to access the admin panel at /admin
# Change this to something only the owner knows.
VITE_ADMIN_PIN=1234
